{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "plan": { "type": "string", "enum": ["free", "pro", "team"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "plan", "created_at"]
    },
    "QRCode": {
      "title": "QRCode",
      "description": "A generated QR code",
      "type": "object",
      "properties": {
        "user_uid": { "type": "string", "description": "Owner UID" },
        "slug": { "type": "string", "description": "Unique short identifier" },
        "destination_url": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "is_active": { "type": "boolean" },
        "type": { "type": "string", "enum": ["url"] },
        "style": {
          "type": "object",
          "properties": {
            "dot_color": { "type": "string" },
            "bg_color": { "type": "string" },
            "dot_style": { "type": "string" }
          }
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_uid", "slug", "destination_url", "title", "is_active", "type", "style", "created_at", "updated_at"]
    },
    "ScanEvent": {
      "title": "ScanEvent",
      "description": "An event recorded when a QR code is scanned",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "scanned_at": { "type": "string", "format": "date-time" },
        "country": { "type": "string" },
        "region": { "type": "string" },
        "city": { "type": "string" },
        "timezone": { "type": "string" },
        "device_type": { "type": "string" },
        "os": { "type": "string" },
        "os_version": { "type": "string" },
        "browser": { "type": "string" },
        "visitor_hash": { "type": "string" },
        "is_unique": { "type": "boolean" },
        "is_bot": { "type": "boolean" },
        "referer_type": { "type": "string" }
      },
      "required": ["slug", "scanned_at", "visitor_hash", "is_unique", "is_bot"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/qr_codes/{qrId}": {
      "schema": { "$ref": "#/entities/QRCode" },
      "description": "QR codes created by users"
    },
    "/scan_events/{eventId}": {
      "schema": { "$ref": "#/entities/ScanEvent" },
      "description": "Analytics events for QR code scans"
    }
  }
}
