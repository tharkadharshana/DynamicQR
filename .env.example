# DynamicQR Environment Variables Example

# --- API & Hosting ---
# APP_URL: The URL where the frontend is hosted (e.g., https://qr.example.com)
# Used for CORS, PayHere callbacks, and QR redirects.
APP_URL="https://your-app.a.run.app"

# PORT: The port the server listens on. Cloud Run sets this automatically.
PORT=3000

# NODE_ENV: Set to 'production' for optimized builds and structured logging.
NODE_ENV="production"

# --- Applet Identity ---
# APPLET_ID: The unique identifier for this applet instance.
APPLET_ID="your-applet-id"

# --- AI Integration ---
# GEMINI_API_KEY: Your Google Gemini API key for AI-powered features.
GEMINI_API_KEY="your-gemini-api-key"

# --- Security & Secrets ---
# INTERNAL_SECRET: Shared secret between the Cloud Run server and Cloudflare Worker.
INTERNAL_SECRET="your-long-random-secret"

# HASH_SALT: Salt used for generating visitor fingerprints and security hashes.
HASH_SALT="your-random-hash-salt"

# --- Firebase (Frontend) ---
# These are used by the Vite build process and must be prefixed with VITE_.
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIRESTORE_DATABASE_ID="(default)"

# --- Firebase (Backend/Direct) ---
FIREBASE_API_KEY="your-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
FIREBASE_APP_ID="your-app-id"
FIRESTORE_DATABASE_ID="(default)"

# --- Billing (PayHere) ---
# PAYHERE_MERCHANT_ID: Your PayHere merchant ID.
PAYHERE_MERCHANT_ID="your-merchant-id"

# PAYHERE_SECRET: Your PayHere merchant secret (used for MD5 signature verification).
PAYHERE_SECRET="your-payhere-secret"

# --- Logging ---
# LOG_LEVEL: Winston logging level (error, warn, info, debug).
LOG_LEVEL="info"
