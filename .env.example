# DynamicQR Environment Variables Example

# --- Vercel Deployment ---
# APP_URL: The URL where the frontend is hosted (e.g., https://your-app.vercel.app)
# Used for CORS, PayHere callbacks, and QR redirects.
APP_URL=

# NODE_ENV: Set to 'production' on Vercel.
NODE_ENV="production"

# --- Security & Secrets ---
# INTERNAL_SECRET: Shared secret between the Cloud Run server and Cloudflare Worker.
# Must match the 'INTERNAL_SECRET' set in Cloudflare via `wrangler secret put`.
INTERNAL_SECRET="your-long-random-secret"

# HASH_SALT: Salt used for generating visitor fingerprints and security hashes.
# Must match the 'HASH_SALT' set in Cloudflare via `wrangler secret put`.
HASH_SALT="your-random-hash-salt"

# --- Firebase ---
# FIREBASE_PROJECT_ID: Your Google Cloud / Firebase project ID.
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_APP_ID="your-app-id"
FIREBASE_API_KEY="your-api-key"
FIREBASE_AUTH_DOMAIN="your-auth-domain"
FIRESTORE_DATABASE_ID="your-firestore-database-id"
FIREBASE_STORAGE_BUCKET="your-storage-bucket"
FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"

# FIREBASE_SERVICE_ACCOUNT: JSON string of your service account key.
# Required for Vercel deployment to authenticate the Admin SDK.
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# Note: The server also requires environment variables or 'firebase-applet-config.json' 
# for Firestore and Admin SDK initialization.

# --- Billing (PayHere) ---
# PAYHERE_MERCHANT_ID: Your PayHere merchant ID.
PAYHERE_MERCHANT_ID="your-merchant-id"

# PAYHERE_SECRET: Your PayHere merchant secret (used for MD5 signature verification).
PAYHERE_SECRET="your-payhere-secret"

# --- Logging ---
# LOG_LEVEL: Winston logging level (error, warn, info, debug).
LOG_LEVEL="info"
