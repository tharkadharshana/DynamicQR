# DynamicQR Environment Variables Example

# --- Vercel Deployment ---
# APP_URL: The URL where the frontend is hosted (e.g., https://your-app.vercel.app)
# Used for CORS, PayHere callbacks, and QR redirects.
APP_URL="https://your-app.vercel.app"

# NODE_ENV: Set to 'production' on Vercel.
NODE_ENV="production"

# --- Security & Secrets ---
# INTERNAL_SECRET: Shared secret between the backend and Cloudflare Worker.
# Must match the secret set in the Worker.
INTERNAL_SECRET="your-long-random-secret"

# HASH_SALT: Salt used for generating visitor fingerprints and security hashes.
# Must match the secret set in the Worker.
HASH_SALT="your-random-hash-salt"

# --- Supabase (Frontend & Backend) ---
# VITE_SUPABASE_URL: The URL of your Supabase project
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: The public anon key for the frontend
VITE_SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: The backend secret key for admin operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Billing (PayHere) ---
# PAYHERE_MERCHANT_ID: Your PayHere merchant ID.
PAYHERE_MERCHANT_ID="your-merchant-id"

# PAYHERE_SECRET: Your PayHere merchant secret.
PAYHERE_SECRET="your-payhere-secret"

# --- Logging ---
# LOG_LEVEL: Winston logging level (error, warn, info, debug).
LOG_LEVEL="info"
