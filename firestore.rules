rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.user_uid;
    }

    function uidUnchanged() {
      return !('user_uid' in request.resource.data) || request.resource.data.user_uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('user_uid' in request.resource.data) || request.resource.data.user_uid == resource.data.user_uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    match /users/{userId} {
      allow read: if true; // Allow backend to read
      allow create: if isOwner(userId) && hasRequiredFields(['email', 'plan', 'created_at']);
      allow update: if isOwner(userId) && request.resource.data.plan == resource.data.plan; // Users can't change their own plan
      allow delete: if false;
    }

    match /qr_codes/{qrId} {
      allow read: if true; // Publicly readable for redirects and analytics
      allow create: if isAuthenticated() && 
                    !exists(/databases/$(database)/documents/qr_codes/$(qrId)) &&
                    request.resource.data.user_uid == request.auth.uid &&
                    hasRequiredFields(['slug', 'destination_url', 'title', 'is_active']) &&
                    isValidUrl(request.resource.data.destination_url);
      allow update: if isDocOwner() && 
                    uidNotModified() &&
                    request.resource.data.slug == resource.data.slug && // slug is immutable
                    (!('destination_url' in request.resource.data) || isValidUrl(request.resource.data.destination_url));
      allow delete: if false; // Soft delete only via is_active
    }

    match /qr_stats/{slug} {
      allow read: if true; // Allow backend and frontend to read
      allow write: if true; // Allow backend to write
    }

    match /scan_events/{eventId} {
      allow read: if true; // Allow backend and frontend to read
      allow write: if true; // Allow backend to write
    }

    // Subscription state (plan + active add-ons)
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if true; // Backend-managed via PayHere webhook
    }

    // Invoice / payment history
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && resource.data.user_uid == request.auth.uid;
      allow write: if true; // Backend-managed via PayHere webhook
    }
  }
}
