rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.user_uid;
    }

    function uidUnchanged() {
      return !('user_uid' in request.resource.data) || request.resource.data.user_uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('user_uid' in request.resource.data) || request.resource.data.user_uid == resource.data.user_uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['email', 'plan', 'created_at']);
      allow update: if isOwner(userId) && request.resource.data.plan == resource.data.plan;
      allow delete: if false;
    }

    match /qr_codes/{qrId} {
      allow read: if true; 
      allow create: if isAuthenticated() && 
                    request.resource.data.user_uid == request.auth.uid &&
                    hasRequiredFields(['slug', 'destination_url', 'title', 'is_active']);
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if false;
    }

    match /qr_stats/{slug} {
      allow read: if false; // All via API
      allow write: if false; 
    }

    match /scan_events/{eventId} {
      allow read: if false; // All via API
      allow write: if false;
    }

    match /subscriptions/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /addon_purchases/{docId} {
      allow read: if resource.data.uid == request.auth.uid;
      allow write: if false;
    }
  }
}
