rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users Collection ─────────────────────────────────────
    match /users/{userId} {
      // Users can only read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── QR Codes Collection ──────────────────────────────────
    match /qr_codes/{slug} {
      // Only the owner can read/update/delete
      allow read: if request.auth != null
                  && resource.data.user_uid == request.auth.uid;

      // Creates must set user_uid to the authenticated user
      allow create: if request.auth != null
                    && request.resource.data.user_uid == request.auth.uid;

      // Updates cannot change the slug or user_uid
      allow update: if request.auth != null
                    && resource.data.user_uid == request.auth.uid
                    && request.resource.data.user_uid == request.auth.uid
                    && request.resource.data.slug == resource.data.slug;

      // No hard deletes — only soft-delete via update
      allow delete: if false;
    }

    // ── Scan Events Collection ───────────────────────────────
    // Only server (admin SDK) writes scan events
    // Users can read their own QR scans (via Cloud Run API)
    match /scan_events/{eventId} {
      allow read: if false;   // Read via server API only
      allow write: if false;  // Write via server admin SDK only
    }

    // ── Catch-all: deny everything else ──────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
